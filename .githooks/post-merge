#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "[post-merge] Running post-pull checks..."

old_rev="${ORIG_HEAD:-}"
new_rev="$(git rev-parse HEAD)"

select_php_bin() {
  local bin
  for bin in php8.5 php8.4 php8.3 php8.2 php; do
    if command -v "$bin" >/dev/null 2>&1; then
      echo "$bin"
      return 0
    fi
  done
  return 1
}

is_lint_target() {
  case "$1" in
    vendor/*|node_modules/*|.git/*|data/cache/*)
      return 1
      ;;
  esac
  return 0
}

PHP_BIN="$(select_php_bin || true)"
current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"

if [ -n "$PHP_BIN" ]; then
  echo "[post-merge] [hook] using $PHP_BIN for lint"
  if [ -n "$old_rev" ] && git rev-parse "$old_rev" >/dev/null 2>&1; then
    changed_php="$(git diff --name-only "$old_rev" "$new_rev" -- '*.php' || true)"
  else
    changed_php="$(git ls-files '*.php')"
  fi

  if [ -n "$changed_php" ]; then
    lint_files=""
    while IFS= read -r file; do
      [ -n "$file" ] || continue
      is_lint_target "$file" || continue
      lint_files+="$file"$'\n'
    done <<< "$changed_php"

    if [ -z "$lint_files" ]; then
      echo "[post-merge] No eligible PHP files for lint"
    fi

    while IFS= read -r file; do
      [ -n "$file" ] || continue
      [ -f "$file" ] || continue
      "$PHP_BIN" -l "$file" >/dev/null
    done <<< "$lint_files"

    if [ -n "$lint_files" ]; then
      echo "[post-merge] PHP lint OK"
    fi
  fi
else
  echo "[post-merge] php not found, skipping lint"
fi

if [ -d "data/cache" ]; then
  find "data/cache" -type f ! -name '.gitkeep' -delete || true
  echo "[post-merge] Cache directory cleaned"
fi

provider_domain="${CLEANMENU_PROVIDER_DOMAIN:-menu.labus.pro}"
tenant_domain="${CLEANMENU_TENANT_DOMAIN:-test.milyidom.com}"
run_release_smoke=0

if [ "$ROOT_DIR" = "/var/www/labus_pro_usr/data/www/menu.labus.pro" ] || [ "${CLEANMENU_RUN_RELEASE_SMOKE:-0}" = "1" ]; then
  run_release_smoke=1
fi

if [ -n "$PHP_BIN" ] && [ -f "scripts/tenant/smoke.php" ] && [ "$run_release_smoke" -eq 1 ]; then
  case "$current_branch" in
    main|release/*)
      if [ -f "scripts/security/capture-baseline.sh" ]; then
        echo "[post-merge] Capturing release baseline..."
        bash scripts/security/capture-baseline.sh "https://${provider_domain}" >/dev/null || true
      fi
      echo "[post-merge] Running provider/tenant regression smoke..."
      "$PHP_BIN" scripts/tenant/smoke.php --provider-domain="$provider_domain" --tenant-domain="$tenant_domain"
      echo "[post-merge] Provider/tenant smoke OK"
      if [ -f "scripts/perf/security-smoke.sh" ]; then
        echo "[post-merge] Running provider security smoke..."
        bash scripts/perf/security-smoke.sh "https://${provider_domain}"
        echo "[post-merge] Provider security smoke OK"
      fi
      ;;
    *)
      echo "[post-merge] Release smoke skipped on branch $current_branch"
      ;;
  esac
fi

echo "[post-merge] Complete"
