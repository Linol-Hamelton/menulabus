#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "[pre-push] Running quick checks..."
remote_name="${1:-}"
remote_url="${2:-}"
push_main=0
push_release=0
declare -a pushed_ranges=()
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${local_ref:-}" ] || continue
  if [ "$local_ref" = "refs/heads/main" ] || [ "${remote_ref:-}" = "refs/heads/main" ]; then
    push_main=1
  fi
  if [[ "$local_ref" == refs/heads/release/* ]] || [[ "${remote_ref:-}" == refs/heads/release/* ]]; then
    push_release=1
  fi
  if [ -z "${local_sha:-}" ]; then
    continue
  fi
  if [ -n "${remote_sha:-}" ] && [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
    pushed_ranges+=("${remote_sha}..${local_sha}")
  elif git show-ref --verify --quiet refs/remotes/origin/main; then
    base_sha="$(git merge-base "$local_sha" refs/remotes/origin/main || true)"
    if [ -n "${base_sha:-}" ]; then
      pushed_ranges+=("${base_sha}..${local_sha}")
    fi
  else
    pushed_ranges+=("${local_sha}^!")
  fi
done

select_php_bin() {
  local bin
  for bin in php8.5 php8.4 php8.3 php8.2 php; do
    if command -v "$bin" >/dev/null 2>&1; then
      echo "$bin"
      return 0
    fi
  done
  return 1
}

is_lint_target() {
  case "$1" in
    vendor/*|node_modules/*|.git/*|data/cache/*)
      return 1
      ;;
  esac
  return 0
}

is_mojibake_target() {
  case "$1" in
    vendor/*|node_modules/*|.git/*|data/cache/*|.playwright-cli/*)
      return 1
      ;;
    *.php|*.js|*.css|*.md|*.html|*.htm|*.json|*.yml|*.yaml|*.txt|*.svg)
      return 0
      ;;
  esac
  return 1
}

PHP_BIN="$(select_php_bin || true)"

if [ -n "$PHP_BIN" ]; then
  echo "[pre-push] [hook] using $PHP_BIN for lint"
  changed_php="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.php$' || true)"
  if [ -n "$changed_php" ]; then
    lint_files=""
    while IFS= read -r file; do
      [ -n "$file" ] || continue
      is_lint_target "$file" || continue
      lint_files+="$file"$'\n'
    done <<< "$changed_php"

    if [ -z "$lint_files" ]; then
      echo "[pre-push] No eligible PHP files for lint"
    fi

    while IFS= read -r file; do
      [ -n "$file" ] || continue
      [ -f "$file" ] || continue
      "$PHP_BIN" -l "$file" >/dev/null
    done <<< "$lint_files"

    if [ -n "$lint_files" ]; then
      echo "[pre-push] PHP lint OK"
    fi
  else
    echo "[pre-push] No staged PHP changes"
  fi
else
  echo "[pre-push] php not found, skipping lint"
fi

if [ -n "$PHP_BIN" ]; then
  declare -A mojibake_seen=()
  mojibake_files=()
  for range in "${pushed_ranges[@]}"; do
    while IFS= read -r file; do
      [ -n "$file" ] || continue
      is_mojibake_target "$file" || continue
      if [ -z "${mojibake_seen[$file]+x}" ]; then
        mojibake_seen["$file"]=1
        mojibake_files+=("$file")
      fi
    done < <(git diff --name-only --diff-filter=ACMR "$range" || true)
  done

  if [ "${#mojibake_files[@]}" -gt 0 ]; then
    echo "[pre-push] Running anti-mojibake check..."
    "$PHP_BIN" scripts/check-mojibake.php "${mojibake_files[@]}"
    echo "[pre-push] Mojibake check OK"
  else
    echo "[pre-push] No changed text files for mojibake check"
  fi
fi

# PHPUnit gate: lifecycle contract + idempotency + createOrder regression.
# The pure-PHP lifecycle suite always runs. MySQL-coupled tests
# (IdempotencyTest, CreateOrderTest) self-skip when
# CLEANMENU_TEST_MYSQL_DSN is not exported — no extra config needed.
if [ -n "$PHP_BIN" ]; then
  phpunit_entry="vendor/phpunit/phpunit/phpunit"
  if [ -f "$phpunit_entry" ]; then
    echo "[pre-push] Running PHPUnit unit suite..."
    "$PHP_BIN" "$phpunit_entry" --testsuite unit
    echo "[pre-push] PHPUnit OK"
  else
    echo "[pre-push] vendor/phpunit not installed; run 'composer install' to enable the test gate"
  fi
fi

if [ "$push_main" -eq 1 ] || [ "$push_release" -eq 1 ]; then
  echo "[pre-push] Running docs drift check for release/main push..."
  bash scripts/docs/check-doc-drift.sh "${pushed_ranges[@]}"
  echo "[pre-push] Docs drift check OK"
fi

# Phase P-2: visual regression check before any release/main push.
# Skipped gracefully when:
#   - playwright is not installed (fresh clone before `npm install`)
#   - .env.local is missing (no owner credentials → suite can't auth)
#   - --no-visual flag is set in CLEANMENU_NO_VISUAL env var (escape hatch)
# When the suite runs and finds a snapshot diff, the push is blocked
# until the operator either fixes the regression or runs
# `npm run visual:update` to refresh baselines.
if [ "$push_main" -eq 1 ] || [ "$push_release" -eq 1 ]; then
  if [ "${CLEANMENU_NO_VISUAL:-0}" = "1" ]; then
    echo "[pre-push] visual regression check skipped (CLEANMENU_NO_VISUAL=1)"
  elif [ ! -f .env.local ]; then
    echo "[pre-push] visual regression check skipped (.env.local missing — see tests/visual/README.md)"
  elif [ ! -d node_modules/@playwright ]; then
    echo "[pre-push] visual regression check skipped (npm install not run yet)"
  elif ! command -v npx >/dev/null 2>&1; then
    echo "[pre-push] visual regression check skipped (npx not on PATH)"
  else
    # Check chromium is installed locally; skip with hint if not.
    if ! npx playwright install --dry-run chromium >/dev/null 2>&1; then
      echo "[pre-push] visual regression check skipped (run 'npx playwright install chromium' once)"
    else
      echo "[pre-push] Running visual regression suite..."
      if npm run --silent visual >/tmp/cleanmenu-visual.log 2>&1; then
        echo "[pre-push] Visual regression OK"
      else
        echo "[pre-push] ERROR: visual regression detected. Last lines:"
        tail -20 /tmp/cleanmenu-visual.log
        echo
        echo "[pre-push] To inspect the diff: npm run visual:report"
        echo "[pre-push] To accept the new look: npm run visual:update && commit"
        echo "[pre-push] To bypass for one push: CLEANMENU_NO_VISUAL=1 git push"
        exit 1
      fi
    fi
  fi
fi

if [ "$push_main" -eq 1 ]; then
  echo "[pre-push] main branch push detected ($remote_name $remote_url), validating OpenAPI..."
  if ! command -v npm >/dev/null 2>&1; then
    echo "[pre-push] ERROR: npm is required for openapi validation before pushing main"
    exit 1
  fi
  npm run --silent openapi:validate
  echo "[pre-push] OpenAPI validation OK"
fi

echo "[pre-push] Done"
