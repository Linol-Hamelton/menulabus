#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "[pre-push] Running quick checks..."
remote_name="${1:-}"
remote_url="${2:-}"
push_main=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${local_ref:-}" ] || continue
  if [ "$local_ref" = "refs/heads/main" ] || [ "${remote_ref:-}" = "refs/heads/main" ]; then
    push_main=1
  fi
done

select_php_bin() {
  local bin
  for bin in php8.5 php8.4 php8.3 php8.2 php; do
    if command -v "$bin" >/dev/null 2>&1; then
      echo "$bin"
      return 0
    fi
  done
  return 1
}

is_lint_target() {
  case "$1" in
    vendor/*|node_modules/*|.git/*|data/cache/*)
      return 1
      ;;
  esac
  return 0
}

PHP_BIN="$(select_php_bin || true)"

if [ -n "$PHP_BIN" ]; then
  echo "[pre-push] [hook] using $PHP_BIN for lint"
  changed_php="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.php$' || true)"
  if [ -n "$changed_php" ]; then
    lint_files=""
    while IFS= read -r file; do
      [ -n "$file" ] || continue
      is_lint_target "$file" || continue
      lint_files+="$file"$'\n'
    done <<< "$changed_php"

    if [ -z "$lint_files" ]; then
      echo "[pre-push] No eligible PHP files for lint"
    fi

    while IFS= read -r file; do
      [ -n "$file" ] || continue
      [ -f "$file" ] || continue
      "$PHP_BIN" -l "$file" >/dev/null
    done <<< "$lint_files"

    if [ -n "$lint_files" ]; then
      echo "[pre-push] PHP lint OK"
    fi
  else
    echo "[pre-push] No staged PHP changes"
  fi
else
  echo "[pre-push] php not found, skipping lint"
fi

if [ "$push_main" -eq 1 ]; then
  echo "[pre-push] main branch push detected ($remote_name $remote_url), validating OpenAPI..."
  if ! command -v npm >/dev/null 2>&1; then
    echo "[pre-push] ERROR: npm is required for openapi validation before pushing main"
    exit 1
  fi
  npm run --silent openapi:validate
  echo "[pre-push] OpenAPI validation OK"
fi

echo "[pre-push] Done"
