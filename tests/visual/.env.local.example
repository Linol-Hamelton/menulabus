# Copy to .env.local (in repo root) before running `npm run visual`.
# .env.local is .gitignored — credentials never leave the dev machine.
#
# CLEANMENU_BASE_URL is optional; defaults to https://menu.labus.pro.
# Override to point at a staging tenant: https://staging.menu.labus.pro

CLEANMENU_BASE_URL=https://menu.labus.pro
CLEANMENU_OWNER_EMAIL=owner@example.com
CLEANMENU_OWNER_PASSWORD=replace-me
